rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRoomPlayer() {
      return isSignedIn() && request.auth.uid in resource.data.playerUids;
    }

    function isAddingSelfToSpectators() {
      return request.auth.uid in request.resource.data.spectatorUids &&
             !(request.auth.uid in resource.data.spectatorUids);
    }

    function isRemovingSelfFromSpectators() {
      return request.auth.uid in resource.data.spectatorUids &&
             !(request.auth.uid in request.resource.data.spectatorUids);
    }

    function isEmptyRoom() {
      return resource.data.players.size() == 0 &&
        (!('spectators' in resource.data) || resource.data.spectators.size() == 0);
    }

    function isAbandonedRoom() {
      return request.time.toMillis() - resource.data.lastActivityAt > 1800000;
    }

    // 使用者資料：所有人可讀
    // 自己可寫（個人資料、暱稱、大頭貼等）
    // 其他玩家也可更新戰績欄位
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSelf(uid) || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['overall', 'byGame', 'displayName', 'photoURL', 'updatedAt'])
      );
      allow delete: if false;
    }

    // 使用者子集合：savedGameHistory（IMPROVEMENTS #22）
    // 個人「我儲存的棋譜」連結，只能操作自己的
    // 刪除 = 軟刪除連結，棋譜本體 gameHistory 不受影響
    match /users/{uid}/savedGameHistory/{entryId} {
      allow read: if isSelf(uid);
      allow create, delete: if isSelf(uid);
      allow update: if false;
    }

    // 使用者子集合：favoriteGameHistory（IMPROVEMENTS #22）
    match /users/{uid}/favoriteGameHistory/{entryId} {
      allow read: if isSelf(uid);
      allow create, delete: if isSelf(uid);
      allow update: if false;
    }

    // 全域 meta 資料
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['userCounter', 'createdAt', 'updatedAt']);
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['userCounter', 'updatedAt']);
      allow delete: if false;
    }

    // 房間
    match /rooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.hostId == request.auth.uid &&
        request.resource.data.status == 'waiting';

      // 更新規則：四種合法情境
      // 允許的欄位含 hostId / spectators / turnStartedAt / turnSymbol / undoUsedByUids / lastHistoryEntryId
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'playerUids', 'hostId', 'status', 'startedAt', 'endedAt', 'winnerId', 'isDraw', 'lastActivityAt', 'spectators', 'spectatorUids', 'turnStartedAt', 'turnSymbol', 'undoUsedByUids', 'lastHistoryEntryId']) &&
        (
          isRoomPlayer() ||
          resource.data.hostId == request.auth.uid ||
          (!(request.auth.uid in resource.data.playerUids) &&
           request.auth.uid in request.resource.data.playerUids) ||
          isAddingSelfToSpectators() ||
          isRemovingSelfFromSpectators()
        ) &&
        (!('turnStartedAt' in request.resource.data) ||
         request.resource.data.turnStartedAt == null ||
         request.resource.data.turnStartedAt <= request.time.toMillis() + 5000);

      // 刪除：房主可刪，或房間已空，或超過 30 分鐘無活動
      allow delete: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        isEmptyRoom() ||
        isAbandonedRoom()
      );

      // 房間密碼子集合：所有人可讀（驗證用），僅房主可寫
      match /secret/{document=**} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() &&
          get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
        allow delete: if isSignedIn() &&
          get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
      }

      // 對戰歷史子集合（rooms/{roomId}/history — 已被 #22 取代但保留相容）
      match /history/{moveId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // IMPROVEMENTS #22 公開棋譜
    // 任何登入者皆可讀（探索、Profile 等場景）
    // 只能由 playerUids 內的玩家建立（archiveFinishedRoomToHistory 寫入時驗證）
    // 棋譜一旦建立就不可改/刪
    match /gameHistory/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.playerUids;
      allow update, delete: if false;
    }

    // 密碼唯一性索引
    match /passwordIndex/{hash} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // 其他集合預設拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
