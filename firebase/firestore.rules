rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRoomPlayer() {
      return isSignedIn() && request.auth.uid in resource.data.playerUids;
    }

    function isEmptyRoom() {
      return resource.data.players.size() == 0;
    }

    function isAbandonedRoom() {
      return request.time.toMillis() - resource.data.lastActivityAt.toMillis() > 1800000;
    }

    // 使用者資料：所有人可讀，僅自己可寫
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['wins', 'losses', 'draws', 'totalGames']);
      allow delete: if false;
    }

    // 房間：所有人可讀，房間玩家可寫
    match /rooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.hostId == request.auth.uid &&
        request.resource.data.status == 'waiting';

      // 更新：僅房間玩家（透過 playerUids 陣列檢查），且只能改特定欄位
      allow update: if isRoomPlayer() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'playerUids', 'status', 'startedAt', 'endedAt', 'winnerId', 'isDraw', 'lastActivityAt']);

      // 刪除：房主可刪，或房間已空，或超過 30 分鐘無活動
      allow delete: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        isEmptyRoom() ||
        isAbandonedRoom()
      );

      // 房間密碼（秘密子集合）：所有人可讀（用於驗證密碼），僅房主可寫
      match /secret/{document=**} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() &&
          get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
        allow delete: if isSignedIn() &&
          get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
      }

      // 對戰歷史子集合
      match /history/{moveId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // 密碼唯一性索引：用密碼 hash 當 document ID
    // 建立後不可修改（強制使用 create），避免覆蓋
    match /passwordIndex/{hash} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;  // 不可改，只能建立後整個刪除
      allow delete: if isSignedIn();  // 房主離開時刪除
    }

    // 對戰歷史集合：玩家可讀自己有參與的記錄
    match /gameHistory/{entryId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.playerUids;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // 其他集合預設拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
