{
  "rules": {
    "rooms-live": {
      "$roomId": {
        // 棋盤狀態：任何登入者可讀寫
        // 原本設計需要 state.players map 來驗證玩家身份，
        // 但目前三個遊戲的 state 都沒有 players 欄位，導致 submitMove 全部被擋
        // 安全 trade-off：state 只影響當前對局（不含 stats），stats 由 Firestore rules 保護
        // （TODO：未來可在 state 加 players map，或改用 Cloud Functions 處理）
        "state": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['board', 'nextSymbol', 'moveCount'])"
        },
        // 玩家在線狀態：僅自己可寫
        "presence": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        // 觀戰者與玩家的即時反應（IMPROVEMENTS #8 延伸）
        // 任何登入者皆可讀寫；資料短暫（sender 3.5s 後自動清掉）
        // 結構：{ emoji, uid, displayName, xPct, createdAt }
        "reactions": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$reactionId": {
            ".validate": "newData.hasChildren(['emoji', 'uid', 'displayName', 'xPct', 'createdAt'])"
          }
        },
        // 房間內聊天（IMPROVEMENTS #20）
        // 任何登入者皆可讀寫；房主 resetRoom 或房間廢棄時整段清掉
        // 結構：{ uid, nickname, text, createdAt }
        "chat": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$msgId": {
            ".validate": "newData.hasChildren(['uid', 'nickname', 'text', 'createdAt'])"
          }
        },
        // 悔棋請求（IMPROVEMENTS #12 悔棋請求）
        // 任何登入者皆可讀；只有「被請求的對手」可同意（會由遊戲 sync 處理），
        // 這裡只擋結構驗證（必填 4 欄位）和基本寫入權限。
        // 結構：{ requesterUid, requesterNickname, targetMoveIndex, createdAt }
        "undoRequest": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['requesterUid', 'requesterNickname', 'targetMoveIndex', 'createdAt'])"
        }
      }
    }
  }
}
